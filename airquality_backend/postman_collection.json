{
  "info": {
    "name": "Air Quality Backend API",
    "description": "Full Postman collection for the Air Quality Django/DRF backend.\n\nBase URL: http://localhost:8000/api\n\nFor authenticated requests, set the Authorization header:\n  Authorization: Token <your_token>",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token",    "value": "paste_your_token_here" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register/", "host": ["{{base_url}}"], "path": ["auth","register",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secure123\",\n  \"password2\": \"secure123\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"token\": \"abc123tokenstring\",\n  \"user_id\": 1,\n  \"username\": \"john\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth","login",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"password\": \"secure123\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"token\": \"abc123tokenstring\",\n  \"user_id\": 1,\n  \"username\": \"john\"\n}"
            },
            {
              "name": "401 Invalid credentials",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"error\": \"Invalid credentials.\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/auth/logout/", "host": ["{{base_url}}"], "path": ["auth","logout",""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Logged out successfully.\"\n}"
            }
          ]
        },
        {
          "name": "My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/auth/me/", "host": ["{{base_url}}"], "path": ["auth","me",""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"username\": \"john\",\n  \"email\": \"john@example.com\",\n  \"bio\": \"\",\n  \"avatar_url\": \"\",\n  \"created_at\": \"2024-01-01T10:00:00Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Stations",
      "item": [
        {
          "name": "List Stations",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/stations/", "host": ["{{base_url}}"], "path": ["stations",""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"Almaty Central\",\n    \"city\": \"Almaty\",\n    \"latitude\": 43.238,\n    \"longitude\": 76.889,\n    \"openaq_location_id\": 229766,\n    \"is_active\": true,\n    \"created_at\": \"2024-01-01T10:00:00Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Create Station (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/stations/", "host": ["{{base_url}}"], "path": ["stations",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Almaty Central\",\n  \"city\": \"Almaty\",\n  \"latitude\": 43.238,\n  \"longitude\": 76.889,\n  \"openaq_location_id\": 229766\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 1,\n  \"name\": \"Almaty Central\",\n  \"city\": \"Almaty\",\n  \"latitude\": 43.238,\n  \"longitude\": 76.889,\n  \"openaq_location_id\": 229766,\n  \"is_active\": true,\n  \"created_at\": \"2024-01-01T10:00:00Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Air Quality",
      "item": [
        {
          "name": "Air Quality Summary",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/air-summary/", "host": ["{{base_url}}"], "path": ["air-summary",""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"station_name\": \"Almaty Central\",\n    \"city\": \"Almaty\",\n    \"latest_aqi\": 87,\n    \"category\": \"moderate\",\n    \"pm25\": 23.4,\n    \"pm10\": 41.2,\n    \"recorded_at\": \"2024-01-15T08:00:00Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "List Readings (by station)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/readings/?station=1",
              "host": ["{{base_url}}"],
              "path": ["readings",""],
              "query": [{ "key": "station", "value": "1" }]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"station\": 1,\n    \"station_name\": \"Almaty Central\",\n    \"aqi\": 87,\n    \"pm25\": 23.4,\n    \"pm10\": 41.2,\n    \"no2\": 12.1,\n    \"o3\": null,\n    \"co\": null,\n    \"category\": \"moderate\",\n    \"recorded_at\": \"2024-01-15T08:00:00Z\",\n    \"source\": \"openaq\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Fetch from OpenAQ (saves to DB)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/fetch-openaq/", "host": ["{{base_url}}"], "path": ["fetch-openaq",""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"saved\": [\n    {\n      \"id\": 5,\n      \"station\": 1,\n      \"station_name\": \"Almaty Central\",\n      \"aqi\": 92,\n      \"pm25\": 25.1,\n      \"category\": \"moderate\",\n      \"recorded_at\": \"2024-01-15T09:00:00Z\",\n      \"source\": \"openaq\"\n    }\n  ],\n  \"errors\": []\n}"
            }
          ]
        },
        {
          "name": "Create Manual Reading",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/readings/", "host": ["{{base_url}}"], "path": ["readings",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"station\": 1,\n  \"aqi\": 75,\n  \"pm25\": 18.5,\n  \"pm10\": 33.0,\n  \"recorded_at\": \"2024-01-15T12:00:00Z\",\n  \"source\": \"manual\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 6,\n  \"station\": 1,\n  \"station_name\": \"Almaty Central\",\n  \"aqi\": 75,\n  \"pm25\": 18.5,\n  \"pm10\": 33.0,\n  \"category\": \"moderate\",\n  \"recorded_at\": \"2024-01-15T12:00:00Z\",\n  \"source\": \"manual\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "News Posts (Full CRUD)",
      "item": [
        {
          "name": "List Published Posts",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/posts/", "host": ["{{base_url}}"], "path": ["posts",""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"title\": \"Almaty Air Quality Report January 2024\",\n    \"slug\": \"almaty-air-quality-report-january-2024\",\n    \"body\": \"This month we recorded...\",\n    \"cover_image_url\": \"\",\n    \"is_published\": true,\n    \"author\": 1,\n    \"author_username\": \"john\",\n    \"comments_count\": 3,\n    \"created_at\": \"2024-01-10T10:00:00Z\",\n    \"updated_at\": \"2024-01-10T10:00:00Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/posts/", "host": ["{{base_url}}"], "path": ["posts",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Smog Alert in Almaty\",\n  \"body\": \"Today's PM2.5 levels exceeded WHO guidelines...\",\n  \"is_published\": true\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 2,\n  \"title\": \"Smog Alert in Almaty\",\n  \"slug\": \"smog-alert-in-almaty\",\n  \"body\": \"Today's PM2.5 levels exceeded WHO guidelines...\",\n  \"is_published\": true,\n  \"author\": 1,\n  \"author_username\": \"john\",\n  \"comments_count\": 0,\n  \"created_at\": \"2024-01-15T10:00:00Z\",\n  \"updated_at\": \"2024-01-15T10:00:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Get Post Detail",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/posts/1/", "host": ["{{base_url}}"], "path": ["posts","1",""] }
          },
          "response": []
        },
        {
          "name": "Update Post (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/posts/2/", "host": ["{{base_url}}"], "path": ["posts","2",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Smog Alert in Almaty (Updated)\",\n  \"body\": \"Updated content here...\",\n  \"is_published\": true\n}"
            }
          },
          "response": []
        },
        {
          "name": "Partial Update Post (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/posts/2/", "host": ["{{base_url}}"], "path": ["posts","2",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_published\": false\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/posts/2/", "host": ["{{base_url}}"], "path": ["posts","2",""] }
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "List Comments for Post",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/posts/1/comments/", "host": ["{{base_url}}"], "path": ["posts","1","comments",""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"post\": 1,\n    \"author\": 1,\n    \"author_username\": \"john\",\n    \"body\": \"Great article!\",\n    \"created_at\": \"2024-01-10T11:00:00Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/posts/1/comments/", "host": ["{{base_url}}"], "path": ["posts","1","comments",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"This is very concerning. Stay safe everyone!\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 2,\n  \"post\": 1,\n  \"author\": 1,\n  \"author_username\": \"john\",\n  \"body\": \"This is very concerning. Stay safe everyone!\",\n  \"created_at\": \"2024-01-15T12:00:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Delete Comment (soft delete)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/comments/2/", "host": ["{{base_url}}"], "path": ["comments","2",""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Comment deleted.\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
